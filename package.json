{
  "name": "youtube-auto-uploader",
  "version": "2.0.0",
  "description": "Advanced YouTube Auto Uploader with Queue, Scheduler, Dashboard & WebSocket",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "docker:build": "docker build -t autoupload:latest .",
    "docker:run": "docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "docker:stop": "docker compose down",
    "setup": "bash scripts/setup-cloud.sh"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^4.22.2",
    "googleapis": "^173.0.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^25.3.0",
    "ws": "^8.21.0"
  }
}
