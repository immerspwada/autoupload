# ─────────────────────────────────────────────────────────────────
# YouTube Auto Uploader — Environment Variables
# Copy to .env for local dev: cp .env.example .env
# On Railway/cloud: set these in the platform's Variables panel
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# ── Cloud deployment ───────────────────────────────────────────────
# Set this to your Railway/Render/Fly domain (no trailing slash)
# Railway sets RAILWAY_PUBLIC_DOMAIN automatically — no need to set it manually
# APP_URL=https://your-app.railway.app

# ── Puppeteer (set automatically in Dockerfile) ────────────────────
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ── YouTube Quota ──────────────────────────────────────────────────
# After getting Extended Quota approval from Google Cloud Console
# YOUTUBE_QUOTA_LIMIT=1000000
