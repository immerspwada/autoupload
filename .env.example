# ─────────────────────────────────────────────────────────────────
# YouTube Auto Uploader — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบ
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=production

# ─── YouTube OAuth ────────────────────────────────────────────────
# Path ไปยัง client_secret.json ที่ดาวน์โหลดจาก Google Cloud Console
# ถ้าไม่ระบุ จะหาไฟล์ client_secret*.json ใน root folder อัตโนมัติ
# GOOGLE_CLIENT_SECRET_PATH=./client_secret.json

# ─── Quota Settings ───────────────────────────────────────────────
# YouTube API daily quota limit (default: 10000 = 6 uploads/day)
# หลังขอ Extended Quota แล้ว ให้ตั้งเป็น 1000000
# YOUTUBE_QUOTA_LIMIT=10000

# ─── Auto-upload Loop ─────────────────────────────────────────────
# เปิด/ปิดการทำงาน 24/7 auto loop (true/false)
# AUTO_LOOP_ENABLED=true

# Keywords สำหรับ TikTok search (คั่นด้วย comma)
# TIKTOK_KEYWORDS=funny cats,cooking,travel thailand

# จำนวนวิดีโอที่ดาวน์โหลดต่อ keyword ต่อรอบ
# TIKTOK_COUNT_PER_KEYWORD=5
