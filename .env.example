# ─────────────────────────────────────────────────────────────────
# YouTube Auto Uploader — Environment Variables
# สำหรับ local: cp .env.example .env  แล้วแก้ค่า
# สำหรับ cloud: ตั้งใน platform Variables panel (ไม่ต้องสร้าง .env file)
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── App URL (สำคัญสำหรับ OAuth redirect) ──────────────────────────
# Railway:  ตั้งอัตโนมัติจาก RAILWAY_PUBLIC_DOMAIN — ไม่ต้องตั้ง
# Fly.io:   APP_URL=https://autoupload.fly.dev
# Render:   APP_URL=https://autoupload.onrender.com
# VPS:      APP_URL=https://yourdomain.com
# APP_URL=https://your-app.railway.app

# ── Puppeteer (ตั้งอัตโนมัติใน Dockerfile) ────────────────────────
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ── YouTube Quota ──────────────────────────────────────────────────
# Default: 10,000 units/day (free tier) = 6 uploads/day
# หลังได้รับ Extended Quota จาก Google:
# YOUTUBE_QUOTA_LIMIT=1000000

# ── Security (optional) ───────────────────────────────────────────
# ตั้ง password ป้องกันหน้า dashboard (ถ้าไม่ตั้ง = ไม่มี auth)
# DASHBOARD_PASSWORD=your_secure_password_here

# ── Google OAuth Credentials ──────────────────────────────────────
# ★ วิธีที่ดีกว่า: upload client_secret.json ผ่าน Volume
# หรือใส่ JSON string ตรงนี้ (สำหรับ platform ที่ไม่มี volume เช่น Render)
# GOOGLE_CLIENT_ID=613869038728-xxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
